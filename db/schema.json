{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Korea Driver CBT Question DB",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "defaultQuestionLang", "defaultExplainLang", "questions"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "generatedAt": { "type": "string" },
    "defaultQuestionLang": { "type": "string" },
    "defaultExplainLang": { "type": "string" },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "ordinal", "type", "prompt", "choices", "answerIndexes", "answerMode", "points", "explanations", "source"],
        "properties": {
          "id": { "type": "string" },
          "ordinal": { "type": "number" },
          "license": { "type": "string" },
          "type": { "enum": ["text", "illustration", "photo", "sign", "video"] },
          "category": { "type": "string" },
          "prompt": { "type": "object", "additionalProperties": { "type": "string" } },
          "choices": {
            "type": "array",
            "minItems": 4,
            "maxItems": 5,
            "items": { "type": "object", "additionalProperties": { "type": "string" } }
          },
          "answerIndexes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "number", "minimum": 0 }
          },
          "answerMode": { "enum": ["single", "multi"] },
          "points": { "type": "number" },
          "media": {
            "type": "object",
            "properties": {
              "type": { "enum": ["image", "video"] },
              "src": { "type": "string" },
              "alt": { "type": "string" }
            },
            "required": ["type", "src"],
            "additionalProperties": true
          },
          "explanations": { "type": "object", "additionalProperties": { "type": "string" } },
          "source": {
            "type": "object",
            "required": ["provider", "editionDate"],
            "properties": {
              "provider": { "type": "string" },
              "editionDate": { "type": "string" },
              "note": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
